# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
*.zip
*.tar.gz
*.tar.bz2
*.tar.xz

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
vendor/

# Go workspace file
go.work
go.work.sum

# env files (keep the committed template visible)
.env
.env.local
.env.*.local
!.env.example

# Editor/IDE
.idea/
.vscode/
.DS_Store
.claude/

vendor.protobuf
bin/

# local config
*.secret
config.local.toml

# local cache
.cache/

# scripts for local tests (but keep checked-in release tooling)
scripts/*
!scripts/build-store-zip.sh
node_modules/
CLAUDE.md

# Plasmo / Parcel build artifacts
.plasmo/
.parcel-cache/
build/
dist/
